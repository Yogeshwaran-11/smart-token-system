# PostgreSQL Database connection string
# For LOCAL development: postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres
# For RENDER: This is automatically set by Render when you link a PostgreSQL database
DATABASE_URL=postgresql://postgres:nambatha@localhost:5432/postgres

# Office Configuration (Type of office this backend is running for)
# Options: BANK, ESEVAI, POST_OFFICE, MUNICIPAL
OFFICE_TYPE=MUNICIPAL
